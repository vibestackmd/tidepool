# Copy to `.env` (gitignored) and fill in. Loaded by `cargo xtask ...`
# via dotenvy. CI uses GitHub Actions secrets with the same names.

# Helius API key, used by `cargo xtask record-helius` and the weekly
# drift-detection job. Get one at https://www.helius.dev/.
HELIUS_API_KEY=

# Optional: override the Helius JSON-RPC endpoint. Defaults to
# https://mainnet.helius-rpc.com. Useful for devnet or a proxy.
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# Optional: override the Helius REST endpoint. Defaults to
# https://api.helius.xyz. Helius serves Wallet API / Enhanced
# Transactions / Webhooks on this host — it's separate from the
# JSON-RPC endpoint above.
# HELIUS_REST_URL=https://api.helius.xyz
