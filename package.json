{
  "name": "surfpool-helius",
  "version": "0.5.1",
  "description": "Helius DAS, running on your laptop. A drop-in Helius-compatible RPC proxy on top of Surfpool.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./decoders": {
      "types": "./dist/decoders/index.d.ts",
      "import": "./dist/decoders/index.js"
    },
    "./compat": {
      "types": "./dist/compat/index.d.ts",
      "import": "./dist/compat/index.js"
    }
  },
  "bin": {
    "surfpool-helius": "./dist/bin/surfpool-helius.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/surfpool-helius.ts",
    "start": "node dist/bin/surfpool-helius.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/TylerTheBuildor/surfpool-helius#readme",
  "bugs": {
    "url": "https://github.com/TylerTheBuildor/surfpool-helius/issues"
  },
  "keywords": [
    "solana",
    "helius",
    "surfpool",
    "das",
    "metaplex",
    "mpl-core",
    "rpc",
    "local-development",
    "testing"
  ],
  "author": "Tyler Buchea <tyler.buchea@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylerTheBuildor/surfpool-helius.git"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@solana/kit": "^6.8.0",
    "@solana/program-client-core": "^6.8.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.1",
    "@codama/renderers-js": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "codama": "^1.6.0",
    "msw": "^2.13.4",
    "nock": "^14.0.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "undici": "^8.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
