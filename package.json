{
  "name": "surfpool-helius",
  "version": "0.1.0",
  "description": "Helius DAS, running on your laptop. A drop-in Helius-compatible RPC proxy on top of Surfpool.",
  "type": "module",
  "main": "./dist/proxy.js",
  "types": "./dist/proxy.d.ts",
  "exports": {
    ".": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js"
    },
    "./decoders": {
      "types": "./dist/decoders/index.d.ts",
      "import": "./dist/decoders/index.js"
    }
  },
  "bin": {
    "surfpool-helius": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/TylerTheBuildor/surfpool-helius#readme",
  "bugs": {
    "url": "https://github.com/TylerTheBuildor/surfpool-helius/issues"
  },
  "keywords": [
    "solana",
    "helius",
    "surfpool",
    "das",
    "metaplex",
    "mpl-core",
    "rpc",
    "local-development",
    "testing"
  ],
  "author": "Tyler Buchea <tyler.buchea@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylerTheBuildor/surfpool-helius.git"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
